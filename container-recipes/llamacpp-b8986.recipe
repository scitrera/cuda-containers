DOCKERFILE=Dockerfile.llamacpp
TARGET=runtime

CUDA_VERSION=13.1.1
BUILD_JOBS=4
CUDA_ARCHITECTURES=121

# llama.cpp uses "b<number>" tags, e.g. b5700
# Set LLAMACPP_VERSION to the build number and LLAMACPP_REF defaults to "b<number>"
LLAMACPP_VERSION=8986
LLAMACPP_REF=b8986

IMAGE_TAG=scitrera/dgx-spark-llama-cpp:b8986-cu131
