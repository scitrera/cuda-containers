# SGLang Nightly Dockerfile
# Based on a PyTorch image with CUDA pre-installed
# Supports tagged releases and main-branch nightly builds

ARG BASE_IMAGE=nvidia/cuda:13.2.0-cudnn-devel-ubuntu24.04

# =============================================================================
# Builder stage: build sglang + sgl-kernel from source
# =============================================================================
FROM ${BASE_IMAGE} AS builder

ARG SGLANG_VERSION=""
ARG SGLANG_REF="main"
ARG BUILD_JOBS=2
ARG CUDA_ARCHITECTURES=121
ARG TORCH_CUDA_ARCH_LIST="12.1a"
ARG NVCC_GENCODE="-gencode=arch=compute_121,code=sm_121"
ARG FLASHINFER_VERSION=""

# Apply constraints to protect our torch/vision/audio versions from accidental upgrades during sgl-kernel build
RUN python3 -c "import torch, torchvision, torchaudio; \
     open('/tmp/torch-constraints.txt','w').write( \
       f'torch=={torch.__version__}\ntorchvision=={torchvision.__version__}\ntorchaudio=={torchaudio.__version__}\n')" \
     && cat /tmp/torch-constraints.txt
ENV PIP_CONSTRAINT=/tmp/torch-constraints.txt \
    UV_CONSTRAINT=/tmp/torch-constraints.txt

RUN apt-get update && apt-get upgrade -y \
    && apt-get install -y --allow-change-held-packages --no-install-recommends \
        python3-pip \
        python3-dev \
        git \
        wget \
        ccache \
        libcudnn9-cuda-13 \
        libibverbs1 \
        rdma-core \
        numactl \
        openmpi-common \
        openmpi-bin && \
    ln -s /usr/lib/$(dpkg-architecture -qDEB_HOST_MULTIARCH)/openmpi /opt/openmpi && \
    rm -rf /var/lib/apt/lists/*

ENV MPI_HOME=/opt/openmpi

RUN pip install uv

# update cmake version
RUN uv pip install --upgrade 'cmake==3.31.10'

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    PIP_CACHE_DIR=/root/.cache/pip \
    UV_CACHE_DIR=/root/.cache/uv \
    UV_SYSTEM_PYTHON=1 \
    UV_BREAK_SYSTEM_PACKAGES=1 \
    UV_LINK_MODE=copy \
    CUDA_HOME=/usr/local/cuda \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas \
    MAX_JOBS=${BUILD_JOBS} \
    NVCC_GENCODE=${NVCC_GENCODE} \
    CCACHE_DIR=/root/.ccache \
    CCACHE_MAXSIZE=10G \
    CCACHE_COMPRESS=1 \
    CMAKE_CXX_COMPILER_LAUNCHER=ccache \
    CMAKE_CUDA_COMPILER_LAUNCHER=ccache \
    PATH=/usr/lib/ccache:$PATH \
    NCCL_HOME=/usr/local \
    LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH \
    CPLUS_INCLUDE_PATH=/usr/local/cuda/targets/sbsa-linux/include/cccl:$CPLUS_INCLUDE_PATH

WORKDIR /data

# Clone sglang repo; SGLANG_REF supports tag, branch, or full commit SHA
RUN if echo "${SGLANG_REF}" | grep -qE '^[0-9a-fA-F]{40}$'; then \
        git clone https://github.com/sgl-project/sglang.git && \
        cd sglang && \
        git checkout "${SGLANG_REF}" && \
        git submodule update --init --recursive; \
    else \
        git clone -b "${SGLANG_REF}" --depth 1 --recursive https://github.com/sgl-project/sglang.git; \
    fi

WORKDIR /data/sglang

# Patch version in pyproject.toml if SGLANG_VERSION is set (for nightly wheel versioning)
RUN if [ -n "${SGLANG_VERSION}" ]; then \
        sed -i "s/^version = .*/version = \"${SGLANG_VERSION}\"/" python/pyproject.toml; \
        if [ -f sgl-kernel/pyproject.toml ]; then \
            sed -i "s/^version = .*/version = \"${SGLANG_VERSION}\"/" sgl-kernel/pyproject.toml; \
        fi; \
    fi

ENV SETUPTOOLS_SCM_PRETEND_VERSION_FOR_SGLANG=${SGLANG_VERSION} \
    SETUPTOOLS_SCM_PRETEND_VERSION=${SGLANG_VERSION}

# Install sglang package (no deps, no build isolation since base has torch)
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    uv pip install --no-build-isolation --no-deps ./python

# Copy any pre-built sgl-kernel wheels from build context (may be empty)
COPY wheel-cache/ /data/wheel-cache/

# Build sgl-kernel: use pre-built wheel if available, otherwise build from source
RUN --mount=type=cache,id=ccache,target=/root/.ccache \
    --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    mkdir -p /data/wheels && \
    if ls /data/wheel-cache/sgl*kernel-*.whl 1>/dev/null 2>&1; then \
        echo "=== Using pre-built sgl-kernel wheel ===" && \
        cp /data/wheel-cache/sgl*kernel-*.whl /data/wheels/; \
    else \
        echo "=== Building sgl-kernel from source ===" && \
        cd sgl-kernel && \
        make install-deps && \
        uv build --wheel \
          -Cbuild-dir=build \
          "-Cbuild.tool-args=-j${MAX_JOBS}" \
          -Ccmake.args=-DSGL_KERNEL_COMPILE_THREADS=1 \
          --out-dir=/data/wheels \
          . --verbose --no-build-isolation; \
    fi

# Build sglang wheel
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    mkdir -p /data/wheels && \
    uv build --wheel --no-build-isolation --no-index \
      --out-dir=/data/wheels ./python

# Install sgl-kernel from the wheel we just built
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    ls /data/wheels/ && \
    uv pip install /data/wheels/sgl*kernel-*.whl --no-deps

# Optional: install specific FlashInfer version from wheels index (skip if blank)
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    if [ -n "$FLASHINFER_VERSION" ]; then \
        uv pip install --pre flashinfer-python==${FLASHINFER_VERSION} --no-deps --index-url https://flashinfer.ai/whl && \
        uv pip install --pre flashinfer-cubin==${FLASHINFER_VERSION} --no-deps --index-url https://flashinfer.ai/whl && \
        uv pip install --pre flashinfer-jit-cache==${FLASHINFER_VERSION} --no-deps --index-url https://flashinfer.ai/whl/cu130; \
    fi

# Install remaining deps: xgrammar, fastsafetensors, ray, numba, grpcio-tools, multimodal support
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    uv pip install \
        packaging \
        xgrammar \
        fastsafetensors \
        ray[default] \
        numba \
        grpcio-tools \
        qwen-vl-utils

# Resolve any missing deps declared in sglang's pyproject.toml
COPY --chmod=0755 stages/missing_deps.py /opt/missing_deps.py
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    cd /data/sglang/python && \
        /opt/missing_deps.py --extra diffusion \
        --ignore sgl-kernel \
        --ignore sglang-kernel \
        --ignore cuda-python \
        --ignore torch \
        --ignore torchaudio \
        --ignore torchvision \
        --ignore torchcodec \
        > missing_deps.txt && \
    uv pip install -r missing_deps.txt && \
    rm missing_deps.txt /opt/missing_deps.py

# TODO: CUSTOM TRITON INSTALL ??
# Install triton package (no deps, no build isolation since base has torch)
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    uv pip install --no-build-isolation triton

# Late transformers install if version is specified
ARG TRANSFORMERS_VERSION=""
ARG TRANSFORMERS_REF=""
ARG TRANSFORMERS_PRE=0
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    if [ -n "$TRANSFORMERS_REF" ]; then \
        uv pip install -U git+https://github.com/huggingface/transformers.git@${TRANSFORMERS_REF}; \
    elif [ -n "$TRANSFORMERS_VERSION" ]; then \
        uv pip install -U transformers==${TRANSFORMERS_VERSION} --pre; \
    elif [ "$TRANSFORMERS_PRE" = "1" ]; then \
        uv pip install -U transformers --pre; \
    fi

# Break up dist-packages into smaller layers to avoid hitting Docker layer size limits
COPY stages/directory_split2.sh /opt/directory_split2.sh
RUN chmod +x /opt/directory_split2.sh && \
    /opt/directory_split2.sh \
      /usr/local/lib/python3.12/dist-packages \
      4

# =============================================================================
# Runtime stage: clean image with installed packages
# =============================================================================
FROM ${BASE_IMAGE} AS runtime

ARG TORCH_CUDA_ARCH_LIST="12.1a"
ENV CUDA_HOME=/usr/local/cuda \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH_LIST} \
    TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas

# runtime base installs
RUN apt update && \
    apt install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-dev \
    vim \
    curl \
    git \
    wget \
    libcudnn9-cuda-13 \
    libnccl-dev \
    libnccl2 \
    libibverbs1 \
    libibverbs-dev \
    rdma-core \
    libxcb1 \
    && rm -rf /var/lib/apt/lists/* && \
    pip install uv && (pip uninstall -y flash-attn || true)

# Copy Python dependencies from builder (split into 4 layers for size management)
COPY --from=builder /usr/local/lib/python3.12/dist-packages-1/ /usr/local/lib/python3.12/dist-packages/
COPY --from=builder /usr/local/lib/python3.12/dist-packages-2/ /usr/local/lib/python3.12/dist-packages/
COPY --from=builder /usr/local/lib/python3.12/dist-packages-3/ /usr/local/lib/python3.12/dist-packages/
COPY --from=builder /usr/local/lib/python3.12/dist-packages-4/ /usr/local/lib/python3.12/dist-packages/
COPY --from=builder /usr/local/bin /usr/local/bin

# Override some ENV variables for runtime use
ENV CCACHE_DIR=/tmp/.ccache

WORKDIR /data/sglang
RUN apt-get clean && rm -rf /var/lib/apt/lists/*

# =============================================================================
# Wheel carrier stage: minimal image containing just the built wheels
# Consumers use: COPY --from=ghcr.io/scitrera/sglang-nightly-wheels:tag /wheels/ /tmp/wheels/
# =============================================================================
FROM scratch AS wheels

COPY --from=builder /data/wheels/ /wheels/
